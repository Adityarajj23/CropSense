# S3-compatible storage (MinIO for local)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_ENDPOINT_URL=http://minio:9000
S3_RAW_BUCKET=crop-analyzer-raw
S3_PROCESSED_BUCKET=crop-analyzer-processed
S3_MODEL_BUCKET=crop-analyzer-models
MODEL_KEY=latest/crop_model.json

# Redis
REDIS_HOST=redis

# Service URLs
INFERENCE_URL=http://inference:8001
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=crop/sensors
FAKE_SENSOR_INTERVAL=5